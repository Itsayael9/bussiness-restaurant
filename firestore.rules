rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /categories/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /dishes/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /restaurant/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /sliderSlides/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
